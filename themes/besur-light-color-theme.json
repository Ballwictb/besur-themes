        "keyword.other.important.scss",
        "support.class",
        "support.class.ruby"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },

    {
      "name": "BESUR Light - Italic",
      "scope": ["markup.italic", "comment"],
      "settings": {
        "fontStyle": "italic"
      }
    },

    {
      "name": "BESUR Light - Underline",
      "scope": ["markup.underline", "*url*", "*link*", "*uri*"],
      "settings": {
        "fontStyle": "underline"
      }
    },

    {
      "name": "BESUR Light - Offwhite / Markdown body",
      "scope": [
        "text.html.markdown",
        "punctuation.definition.list_item.markdown",
        "markup.italic"
